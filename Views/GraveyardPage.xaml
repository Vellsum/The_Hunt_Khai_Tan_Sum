<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="The_Hunt_Khai_Tan_Sum.Views.GraveyardPage"
             Title="The Graveyard"
             BackgroundColor="White">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="App GRAVEYARD"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="Black"/>

        <Label Text="Select the apps you want to add to your graveyard."
               TextColor="Gray"
               FontSize="14"
               HorizontalOptions="Center"/>

        <Frame BorderColor="#E8F0D1"
               CornerRadius="10"
               Padding="15">

            <VerticalStackLayout Spacing="10">

                <HorizontalStackLayout Spacing="20">
                    <CheckBox x:Name="TikTokCheck"/>
                    <Label Text="TikTok"
                           VerticalOptions="Center"
                           FontSize="18"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="20">
                    <CheckBox x:Name="InstagramCheck"/>
                    <Label Text="Instagram"
                           VerticalOptions="Center"
                           FontSize="18"/>
                </HorizontalStackLayout>

				<HorizontalStackLayout Spacing="20">
					<CheckBox x:Name="YouTubeCheck" />
					<Label Text="YouTube"
                           VerticalOptions="Center"
                           FontSize="18"/>
				</HorizontalStackLayout>


				<HorizontalStackLayout Spacing="20">
					<CheckBox x:Name="FaceBookCheck"/>
					<Label Text="Facebook"
                           VerticalOptions="Center"
                           FontSize="18"/>
				</HorizontalStackLayout>

            </VerticalStackLayout>

        </Frame>

        <Button Text="Save Apps"
                BackgroundColor="#D1FFBD"
                TextColor="Black"
                FontAttributes="Bold"
                CornerRadius="15"
                HeightRequest="50"
                Clicked="OnBuryClicked"/>

    </VerticalStackLayout>
</ContentPage>