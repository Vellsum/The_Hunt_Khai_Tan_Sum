<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="The_Hunt_Khai_Tan_Sum.Views.GraveyardPage"
             BackgroundColor="{AppThemeBinding Light=#F5F5F2, Dark=#0F0F0F}">

    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="18"
                             MaximumWidthRequest="420"
                             HorizontalOptions="Center">

            <!-- TITLE -->
            <Label Text="The Graveyard"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Label Text="Select Apps to Hunt"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

            <!-- APP LIST -->
            <CollectionView ItemsSource="{Binding Apps}"
                            SelectionMode="None"
                            Margin="0,10,0,0">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <!-- CARD -->
                        <Border BackgroundColor="{AppThemeBinding Light=#EDEDED, Dark=#1A1A1A}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 20"
                                Padding="12"
                                Margin="0,0,0,12">

                            <Grid ColumnDefinitions="60,*,Auto"
                                  VerticalOptions="Center">

                                <!-- ICON -->
                                <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#EAEAEA}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 18"
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        Padding="8">

                                    <Image Source="{Binding Icon}"
                                           Aspect="AspectFit"
                                           WidthRequest="30"
                                           HeightRequest="30"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>   
                                </Border>

                                <!-- NAME -->
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       Margin="10,0,0,10"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <!-- SWITCH -->
                                <Switch Grid.Column="2"
                                        IsToggled="{Binding IsSelected}"
                                        OnColor="#A6D89B"
                                        ThumbColor="White"
                                        Scale="0.9"
                                        Margin="0,0,0,10"
                                        VerticalOptions="Center"/>
                            </Grid>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- BUTTONS -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="16"
                  Margin="0,10,0,25">

                <Button Grid.Column="0"
                        Text="BACK"
                        Command="{Binding BackCommand}"
                        BackgroundColor="#F3C96B"
                        TextColor="Black"
                        FontAttributes="Bold"
                        CornerRadius="22"
                        HeightRequest="50"/>

                <Button Grid.Column="1"
                        Text="SAVE"
                        Command="{Binding SaveAppsCommand}"
                        BackgroundColor="#8FB7C9"
                        TextColor="Black"
                        FontAttributes="Bold"
                        CornerRadius="22"
                        Margin="0,0,0,10"
                        HeightRequest="50"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>