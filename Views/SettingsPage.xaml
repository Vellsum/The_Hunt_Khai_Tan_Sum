<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:The_Hunt_Khai_Tan_Sum.Converters"
             x:Class="The_Hunt_Khai_Tan_Sum.Views.SettingsPage"
             BackgroundColor="{AppThemeBinding Light=#F5F5F2, Dark=#0F0F0F}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="20"
                             MaximumWidthRequest="420"
                             HorizontalOptions="Center">

            <!-- TITLE -->
            <Label Text="SETTINGS"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <!-- DARK MODE -->
            <Border BackgroundColor="{AppThemeBinding Light=#EDEDED, Dark=#1A1A1A}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 15"
                    Padding="5">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Dark Mode"
                           FontSize="16"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Switch Grid.Column="1"
                            IsToggled="{Binding IsDarkModeEnabled}"
                            VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- TIMER ENABLE -->
            <Border BackgroundColor="{AppThemeBinding Light=#EDEDED, Dark=#1A1A1A}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 20"
                    Padding="16">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Enable Timer Delay"
                           FontSize="16"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Switch Grid.Column="1"
                            IsToggled="{Binding IsTimerDelayEnabled}"
                            VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- TIMER BLOCK -->
            <VerticalStackLayout IsVisible="{Binding IsTimerSetupVisible}"
                                 Spacing="14">

                <HorizontalStackLayout Spacing="12"
                                       HorizontalOptions="Center">

                    <Border BackgroundColor="#B8C6F2"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 12"
                            WidthRequest="70"
                            HeightRequest="60">
                        <Label Text="{Binding Hours}"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Border BackgroundColor="#B8C6F2"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 12"
                            WidthRequest="70"
                            HeightRequest="60">
                        <Label Text="{Binding Minutes}"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Border BackgroundColor="#B8C6F2"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 12"
                            WidthRequest="70"
                            HeightRequest="60">
                        <Label Text="{Binding Seconds}"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                </HorizontalStackLayout>

                <Label Text="Select delay time"
                       FontSize="12"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                <!-- PICKERS -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                    <Picker ItemsSource="{Binding HourOptions}"
                            SelectedItem="{Binding SelectedHour}"
                            Title="HH"/>

                    <Picker Grid.Column="1"
                            ItemsSource="{Binding MinuteOptions}"
                            SelectedItem="{Binding SelectedMinute}"
                            Title="MM"/>

                    <Picker Grid.Column="2"
                            ItemsSource="{Binding SecondOptions}"
                            SelectedItem="{Binding SelectedSecond}"
                            Title="SS"/>

                </Grid>

            </VerticalStackLayout>

            <!-- MODE -->
            <Label Text="HUNT Behavior"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Border BackgroundColor="{AppThemeBinding Light=#EDEDED, Dark=#1A1A1A}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 20"
                    Padding="16">

                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="Auto,*">
                        <RadioButton IsChecked="{Binding IsPoltergeistMode, Converter={StaticResource InvertedBoolConverter}}"/>
                        <Label Grid.Column="1"
                               Text="Whisper Mode"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <RadioButton IsChecked="{Binding IsPoltergeistMode}"/>
                        <Label Grid.Column="1"
                               Text="Poltergeist Mode"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!--Degital LOCKDOWN -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Digital Lockdown"
                       FontSize="16"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <Switch Grid.Column="1"
                        IsToggled="{Binding IsDigitalLockdownEnabled}"/>
            </Grid>

            <!--Run BACKGROUND -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Run in Background"
                       FontSize="16"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                <Switch Grid.Column="1"
                        IsToggled="{Binding IsRunInBackgroundEnabled}"/>
            </Grid>

            <!-- BUTTONS -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="16">

                <Button Text="BACK"
                        Command="{Binding BackCommand}"
                        BackgroundColor="#F3C96B"
                        TextColor="Black"
                        HeightRequest="50"
                        FontSize="15"
                        WidthRequest="150"
                        FontAttributes="Bold"
                        CornerRadius="20"/>

                <Button Grid.Column="1"
                        Text="SAVE"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        WidthRequest="150"
                        FontSize="15"
                        Command="{Binding SaveSettingsCommand}"
                        BackgroundColor="#8FB7C9"
                        TextColor="Black"
                        CornerRadius="20"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>