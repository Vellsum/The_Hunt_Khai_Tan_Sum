<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:The_Hunt_Khai_Tan_Sum.ViewModels"
             x:Class="The_Hunt_Khai_Tan_Sum.Views.SettingsPage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="30" 
                             Spacing="15"
                             MaximumWidthRequest="400"
                             HorizontalOptions="Center">

            <Grid ColumnDefinitions="*, Auto" Margin="0,10">
                <Label Text="Timer Settings" 
                       FontSize="28" 
                       FontAttributes="Bold, Italic" 
                       TextColor="Black" 
                       VerticalOptions="Center" />
                <Image Grid.Column="1" Source="settings_icon.png" WidthRequest="30" HeightRequest="30" />
            </Grid>

            <Border BackgroundColor="#E9E9DB" StrokeShape="RoundRectangle 25" Padding="20,10" Stroke="Transparent">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Enable Timer Delay" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="Black" 
                           VerticalOptions="Center"/>
                    <Switch Grid.Column="1" IsToggled="{Binding IsTimerDelayEnabled}" OnColor="Black" ThumbColor="White"/>
                </Grid>
            </Border>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="15" Margin="0,15" IsVisible="{Binding IsTimerSetupVisible}">
                <Border BackgroundColor="#A4C2F4" WidthRequest="75" HeightRequest="70" StrokeShape="RoundRectangle 5" Stroke="Transparent">
                    <TimePicker Time="{Binding SelectedDelayTime}" 
                                Format="HH" 
                                FontSize="32"
                                FontAttributes="Bold" 
                                TextColor="#112244" 
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                </Border>
                <Border BackgroundColor="#A4C2F4" WidthRequest="75" HeightRequest="70" StrokeShape="RoundRectangle 5" Stroke="Transparent">
                    <TimePicker Time="{Binding SelectedDelayTime}" 
                                Format="mm" FontSize="32" 
                                FontAttributes="Bold" 
                                TextColor="#112244"
                                HorizontalOptions="Center" 
                                VerticalOptions="Center"/>
                </Border>
                <Border BackgroundColor="#A4C2F4" WidthRequest="75" HeightRequest="70" StrokeShape="RoundRectangle 5" Stroke="Transparent">
                    <TimePicker Time="{Binding SelectedDelayTime}"
                                Format="ss" 
                                FontSize="32" 
                                FontAttributes="Bold"
                                TextColor="#112244" 
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                </Border>
            </HorizontalStackLayout>

            <Label Text="HUNT Behavior" FontSize="20" FontAttributes="Bold, Italic" TextColor="Black" />
            <Border BackgroundColor="#F1F5FF" StrokeShape="RoundRectangle 20" Padding="15" Stroke="Transparent">
                <VerticalStackLayout Spacing="10">
                    <RadioButton Content="Whisper Mode" 
                                 IsChecked="{Binding IsPoltergeistMode, Converter={StaticResource InvertedBoolConverter}}"
                                 FontAttributes="Bold" />
                    <RadioButton Content="Poltergeist Mode" IsChecked="{Binding IsPoltergeistMode}" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Edit App Blacklist" FontSize="18" FontAttributes="Bold" TextColor="Black" />
            <Border BackgroundColor="#F1F5FF" 
                    StrokeShape="RoundRectangle 20" 
                    Padding="15,8"
                    HorizontalOptions="Start" 
                    Stroke="Transparent">
                <HorizontalStackLayout Spacing="10">
                    <Ellipse WidthRequest="20" HeightRequest="20" Fill="#DDE4EF" VerticalOptions="Center"/>
                    <Label Text="Clear History &amp; Data" 
                           TextColor="#777777" 
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                <Label Text="Digital Lockdown" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                <Switch Grid.Column="1" IsToggled="{Binding IsDigitalLockdownEnabled}" OnColor="#BCC78E" Scale="0.9"/>
            </Grid>

            <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                <Label Text="Run in Background" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                <Switch Grid.Column="1" IsToggled="{Binding IsRunInBackgroundEnabled}" OnColor="Black" Scale="0.9"/>
            </Grid>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="30" Margin="0,20">
                <Button Text="BACK" Command="{Binding BackCommand}" 
                        BackgroundColor="#FFCC66" TextColor="Black" 
                        FontAttributes="Bold" CornerRadius="20" HeightRequest="45"/>

                <Button Text="SAVE" Command="{Binding SaveSettingsCommand}" 
                        BackgroundColor="#61AFEF" TextColor="Black" 
                        FontAttributes="Bold" CornerRadius="20" HeightRequest="45"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>