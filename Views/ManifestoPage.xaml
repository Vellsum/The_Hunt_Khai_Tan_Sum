<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="The_Hunt_Khai_Tan_Sum.Views.ManifestoPage"
             BackgroundColor="White">

    <VerticalStackLayout Padding="30" Spacing="0" VerticalOptions="Center" HorizontalOptions="Center">

        <Label Text="MANIFESTO!" 
               FontSize="36" 
               FontAttributes="Bold, Italic" 
               TextColor="Black" 
               HorizontalOptions="Center" 
               Margin="0,0,0,10"/>

        <Label Text="Write your Future self a message" 
               FontSize="20" 
               FontAttributes="Italic" 
               TextColor="Black" 
               HorizontalOptions="Center" 
               HorizontalTextAlignment="Center" 
               Margin="0,0,0,40"/>

        <Border Margin="0,0,0,60" 
                WidthRequest="300" 
                HeightRequest="300" 
                BackgroundColor="#F0F0F0"
                Stroke="Gray"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 40">
            <Editor x:Name="ManifestoEditor"
                    Placeholder="Enter your message..." 
                    TextColor="Black" 
                    FontSize="18"
                    Margin="20"
                    BackgroundColor="Transparent"/>
        </Border>

        <Button Text="Save Manifesto" 
                Command="{Binding SaveManifestoCommand}" 
                TextColor="Black" 
                FontSize="22" 
                FontAttributes="Bold"
                BackgroundColor="#FFB6C1" 
                CornerRadius="30" 
                HeightRequest="70" 
                WidthRequest="280" 
                HorizontalOptions="Center" />   


    </VerticalStackLayout>
</ContentPage>