<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="The_Hunt_Khai_Tan_Sum.Views.ManifestoPage"
             Title="Manifesto">

	<VerticalStackLayout Padding="30" Spacing="20">

		<Label Text="Write Your Manifesto"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <Label Text="Write a reminder of why you are staying focused."
               TextColor="Gray"
               HorizontalOptions="Center"/>

		<Border Stroke="#D1FFBD"
                StrokeThickness="2"
                HeightRequest="200">
   
                <Editor Text="{Binding UserMessage, Mode=TwoWay}"
                        Placeholder="I am hunting distractions because... "
                        FontSize="18"
                        AutoSize="TextChanges" />
                
         </Border>

		<Button Text="Save Message"
                Command="{Binding SaveManifestoCommand}"
                BackgroundColor="#D1FFBD"
                TextColor="Black"
                CornerRadius="20"
                HeightRequest="50" />

	</VerticalStackLayout>

</ContentPage>