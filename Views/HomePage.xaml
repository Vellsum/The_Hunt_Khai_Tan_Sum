<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="The_Hunt_Khai_Tan_Sum.Views.HomePage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" HorizontalOptions="Center" VerticalOptions="Start">

            <Label Text="HOME/ DASHBOARD" 
                   HorizontalOptions="Center"
                   FontSize="30" 
                   FontAttributes="Bold, Italic" 
                   TextColor="Black" 
                   Margin="0,0,0,20"/>

            <HorizontalStackLayout Spacing="15">
                <Border StrokeShape="RoundRectangle 30" 
                        BackgroundColor="Black" 
                        HeightRequest="55" 
                        WidthRequest="55">
                    <Label Text="{Binding AppCount}" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" 
                           TextColor="White" 
                           FontSize="20" 
                           FontAttributes="Bold" />
                </Border>
                <Button Text="Graveyard [Select Apps]" 
                        BackgroundColor="#E8F0D1" 
                        TextColor="Black" 
                        CornerRadius="20"      
                        WidthRequest="260"
                        Clicked="OnGraveyardClicked" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15">
                <Label Text="💬" FontSize="45" VerticalOptions="Center" />
                <Button Text="Manifesto [Write Message]" 
                        BackgroundColor="#E8F0D1" 
                        TextColor="Black" 
                        CornerRadius="20"
                        WidthRequest="260"
                        Clicked="OnManifestoClicked" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15">
                <Label Text="🕒" FontSize="45" VerticalOptions="Center" />
                <Button Text="History"
                        BackgroundColor="#E8F0D1" 
                        TextColor="Black" 
                        CornerRadius="20"
                        WidthRequest="260"
                        Clicked="OnHistoryClicked" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="15">
                <Label Text="⚙️" FontSize="45" VerticalOptions="Center" />
                <Button Text="Settings" 
                        BackgroundColor="#E8F0D1" 
                        TextColor="Black" 
                        CornerRadius="20"
                        WidthRequest="260"
                        Clicked="OnSettingsClicked" />
            </HorizontalStackLayout>

            <Label Text="{Binding HuntStatusText}"
                   FontSize="22"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="Black"
                   Margin="0,60,0,10" />

            <Button Text="Start HUNT" 
                    Command="{Binding ToggleHuntCommand}"
                    BackgroundColor="#D1FFBD" 
                    TextColor="Black" 
                    FontSize="24" 
                    FontAttributes="Bold"
                    HeightRequest="80"
                    WidthRequest="280"
                    CornerRadius="30"
                    HorizontalOptions="Center"
                    Clicked="OnStartHuntClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>