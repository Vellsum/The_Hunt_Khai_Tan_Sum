<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:The_Hunt_Khai_Tan_Sum"
             x:Class="The_Hunt_Khai_Tan_Sum.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Background -->
            <Color x:Key="LightBackground">#F7F7F4</Color>
            <Color x:Key="DarkBackground">#121212</Color>

            <!-- Text -->
            <Color x:Key="LightText">Black</Color>
            <Color x:Key="DarkText">White</Color>

            <!-- Card -->
            <Color x:Key="LightCard">#EEF2FB</Color>
            <Color x:Key="DarkCard">#1E1E1E</Color>

        </ResourceDictionary>
    </Application.Resources>
</Application>
